<UserControl x:Class="CDR_AI_Assistant.Zhushou"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#2D2D30">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0D7C66">
            <TextBlock Text="CDR AI Assistant"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
            <StackPanel>
                <TextBlock Text="Status: Ready" Foreground="#90EE90" Margin="0,0,0,10"/>
                <Button Content="Test Connection" Padding="10,5" Background="#0D7C66" Foreground="White" BorderThickness="0" Click="TestButton_Click" Margin="0,0,0,10"/>
                <CheckBox x:Name="ThemeCheck" Content="Dark Theme" IsChecked="True" Foreground="White" Checked="ThemeCheck_Changed" Unchecked="ThemeCheck_Changed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
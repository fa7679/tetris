<Window x:Class="CDR_AI_Assistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CDR AI 助手" Height="620" Width="400"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#2D2D30" CornerRadius="10" BorderBrush="#3E3E42" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="10,10,0,0" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="CDR AI 助手" Foreground="White" FontSize="14"
                               VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <Button Content="✕" HorizontalAlignment="Right" Width="30" Height="30"
                            Background="Transparent" Foreground="Gray" BorderThickness="0"
                            Click="CloseButton_Click" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- TabControl -->
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="5">

                <!-- Tab 1: 工具箱 -->
                <TabItem Header="工具箱">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="15">
                            <TextBlock Text="基础工具" Foreground="#0D7C66" FontWeight="Bold" Margin="0,0,0,10"/>

                            <Button Content="🔀 一键转曲" Click="ConvertToCurves_Click" HorizontalAlignment="Stretch" Margin="0,0,0,5"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <Button Content="📁 导出 PNG" Click="ExportPNG_Click" Width="110" Margin="0,0,5,0"/>
                                <Button Content="📷 导出 JPG" Click="ExportJPG_Click" Width="110"/>
                            </StackPanel>

                            <Button Content="🎯 智能对齐（页面中心）" Click="SmartAlign_Click" HorizontalAlignment="Stretch" Margin="0,0,0,10"/>

                            <TextBlock Text="对齐方式" Foreground="White" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <Button Content="居中" Width="60" Click="AlignCenter_Click" Margin="0,0,3,0"/>
                                <Button Content="左对齐" Width="60" Click="AlignLeft_Click" Margin="0,0,3,0"/>
                                <Button Content="右对齐" Width="60" Click="AlignRight_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <Button Content="上对齐" Width="60" Click="AlignTop_Click" Margin="0,0,3,0"/>
                                <Button Content="下对齐" Width="60" Click="AlignBottom_Click" Margin="0,0,3,0"/>
                                <Button Content="页面中心" Width="80" Click="AlignToPageCenter_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <Button Content="水平居中" Width="75" Click="AlignHCenter_Click" Margin="0,0,3,0"/>
                                <Button Content="垂直居中" Width="75" Click="AlignVCenter_Click"/>
                            </StackPanel>

                            <Separator Margin="0,15" Background="#3E3E42"/>

                            <TextBlock Text="测试功能" Foreground="#0D7C66" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Button Content="🧪 创建测试矩形" Click="CreateTestRectangle_Click" HorizontalAlignment="Stretch" Margin="0,0,0,5"/>
                            <Button Content="📋 获取选中对象信息" Click="GetSelectedInfo_Click" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: AI 文案 -->
                <TabItem Header="AI 文案">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="15">
                            <TextBlock Text="AI 模型" Foreground="White" Margin="0,0,0,5"/>
                            <ComboBox x:Name="ModelSelector" Margin="0,0,0,10"
                                      SelectionChanged="ModelSelector_SelectionChanged">
                                <ComboBoxItem Content="OpenAI (GPT-4o)" IsSelected="True"/>
                                <ComboBoxItem Content="Claude (Claude 3.5)"/>
                            </ComboBox>

                            <TextBlock Text="提示词" Foreground="White" Margin="0,0,0,5"/>
                            <TextBox x:Name="PromptInput" Height="80"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,10"/>

                            <CheckBox x:Name="UseContextCheckBox" Content="使用选中的文本作为上下文" Foreground="White" Margin="0,0,0,10"/>

                            <TextBlock Text="选中的文本内容（上下文）" Foreground="#888" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ContextText" Height="40"
                                         IsReadOnly="True" Background="#1E1E1E"
                                         Foreground="#888" Margin="0,0,5,0"/>
                                <Button Content="📥" Grid.Column="1" Width="30" Click="LoadContext_Click" ToolTip="加载选中文本"/>
                            </Grid>

                            <Button x:Name="GenerateTextBtn" Content="✨ 生成文案" Click="GenerateText_Click"
                                    HorizontalAlignment="Stretch" Margin="0,10,0,0"/>

                            <TextBlock x:Name="StatusText" Foreground="LightGreen" Margin="0,10,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 3: AI 绘图 -->
                <TabItem Header="AI 绘图">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="15">
                            <TextBlock Text="提示词" Foreground="White" Margin="0,0,0,5"/>
                            <TextBox x:Name="ImagePrompt" Height="60"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="负向提示词" Foreground="White" Margin="0,0,0,5"/>
                            <TextBox x:Name="NegativePrompt" Height="40"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="图片尺寸" Foreground="White" Margin="0,0,0,5"/>
                            <ComboBox x:Name="SizeSelector" Margin="0,0,0,10">
                                <ComboBoxItem Content="512x512" IsSelected="True"/>
                                <ComboBoxItem Content="768x768"/>
                                <ComboBoxItem Content="1024x1024"/>
                                <ComboBoxItem Content="1536x1536"/>
                            </ComboBox>

                            <Button x:Name="GenerateImageBtn" Content="🎨 生成图片" Click="GenerateImage_Click"
                                    HorizontalAlignment="Stretch"/>

                            <Separator Margin="0,15" Background="#3E3E42"/>

                            <TextBlock Text="图生图模式" Foreground="#0D7C66" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Button Content="🖼️ 以图生图（需先选中位图）" Click="ImageToImage_Click"
                                    HorizontalAlignment="Stretch"/>

                            <Image x:Name="PreviewImage" Height="150" Margin="0,10"
                                   Stretch="Uniform" Background="#1E1E1E"/>

                            <TextBlock x:Name="ImageStatusText" Foreground="LightGreen" Margin="0,5,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 4: 翻译 -->
                <TabItem Header="翻译">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="15">
                            <TextBlock Text="翻译服务" Foreground="White" Margin="0,0,0,5"/>
                            <ComboBox x:Name="TranslationServiceSelector" Margin="0,0,0,10">
                                <ComboBoxItem Content="DeepL" IsSelected="True"/>
                                <ComboBoxItem Content="Google Translate"/>
                            </ComboBox>

                            <TextBlock Text="目标语言" Foreground="White" Margin="0,0,0,5"/>
                            <ComboBox x:Name="TargetLangSelector" Margin="0,0,0,10">
                                <ComboBoxItem Content="中文" Tag="ZH" IsSelected="True"/>
                                <ComboBoxItem Content="英文" Tag="EN"/>
                                <ComboBoxItem Content="日文" Tag="JA"/>
                                <ComboBoxItem Content="韩文" Tag="KO"/>
                                <ComboBoxItem Content="法文" Tag="FR"/>
                                <ComboBoxItem Content="德文" Tag="DE"/>
                                <ComboBoxItem Content="西班牙文" Tag="ES"/>
                                <ComboBoxItem Content="意大利文" Tag="IT"/>
                                <ComboBoxItem Content="俄文" Tag="RU"/>
                                <ComboBoxItem Content="葡萄牙文" Tag="PT"/>
                                <ComboBoxItem Content="荷兰文" Tag="NL"/>
                                <ComboBoxItem Content="波兰文" Tag="PL"/>
                                <ComboBoxItem Content="土耳其文" Tag="TR"/>
                                <ComboBoxItem Content="乌克兰文" Tag="UK"/>
                                <ComboBoxItem Content="瑞典文" Tag="SV"/>
                            </ComboBox>

                            <TextBlock Text="待翻译文本" Foreground="White" Margin="0,0,0,5"/>
                            <TextBox x:Name="TranslateInput" Height="80"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,10"/>

                            <Button x:Name="TranslateBtn" Content="🌐 翻译" Click="Translate_Click"
                                    HorizontalAlignment="Stretch"/>

                            <TextBlock Text="翻译结果" Foreground="White" Margin="0,15,0,5"/>
                            <TextBox x:Name="TranslateOutput" Height="80"
                                     IsReadOnly="True" Background="#1E1E1E"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 5: 设置 -->
                <TabItem Header="设置">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="15">
                            <TextBlock Text="AI 提供商" Foreground="White" Margin="0,0,0,5"/>
                            <ComboBox x:Name="AIProviderSelector" Margin="0,0,0,10"
                                      SelectionChanged="AIProviderSelector_SelectionChanged">
                                <ComboBoxItem Content="OpenAI" IsSelected="True"/>
                                <ComboBoxItem Content="Claude"/>
                                <ComboBoxItem Content="Stable Diffusion"/>
                                <ComboBoxItem Content="Midjourney"/>
                            </ComboBox>

                            <TextBlock Text="API Base URL" Foreground="White" Margin="0,0,0,5"/>
                            <TextBox x:Name="BaseURLInput" Margin="0,0,0,5"
                                    Text="https://api.openai.com/v1"/>

                            <TextBlock Text="API Key" Foreground="White" Margin="0,0,0,5"/>
                            <PasswordBox x:Name="ApiKeyInput" Margin="0,0,0,5"/>

                            <TextBlock Text="模型名称" Foreground="White" Margin="0,0,0,5"/>
                            <TextBox x:Name="ModelNameInput" Margin="0,0,0,5" Text="gpt-4o"/>

                            <TextBlock Text="超时时间（秒）" Foreground="White" Margin="0,0,0,5"/>
                            <TextBox x:Name="TimeoutInput" Margin="0,0,0,10" Text="120"/>

                            <Separator Margin="0,10" Background="#3E3E42"/>

                            <TextBlock Text="DeepL 翻译设置" Foreground="#0D7C66" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="DeepL API Key" Foreground="White" Margin="0,0,0,5"/>
                            <PasswordBox x:Name="DeepLApiKeyInput" Margin="0,0,0,10"/>

                            <Separator Margin="0,10" Background="#3E3E42"/>

                            <TextBlock Text="Google 翻译设置" Foreground="#0D7C66" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="Google API Key" Foreground="White" Margin="0,0,0,5"/>
                            <TextBox x:Name="GoogleApiKeyInput" Margin="0,0,0,10"/>

                            <Separator Margin="0,10" Background="#3E3E42"/>

                            <TextBlock Text="Midjourney 设置" Foreground="#0D7C66" FontWeight="Bold" Margin="0,0,0,5"/>
                            <CheckBox x:Name="MidjourneyEnabledCheckBox" Content="启用 Midjourney" Foreground="White" Margin="0,0,0,5"/>
                            <TextBlock Text="API URL" Foreground="White" Margin="0,0,0,5"/>
                            <TextBox x:Name="MidjourneyApiUrlInput" Margin="0,0,0,5"/>
                            <TextBlock Text="回调 URL" Foreground="White" Margin="0,0,0,5"/>
                            <TextBox x:Name="MidjourneyCallbackUrlInput" Margin="0,0,0,10"/>

                            <Separator Margin="0,10" Background="#3E3E42"/>

                            <TextBlock Text="导出设置" Foreground="#0D7C66" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="默认图片尺寸" Foreground="White" Margin="0,0,0,5"/>
                            <TextBox x:Name="DefaultImageSizeInput" Margin="0,0,0,5" Text="512x512"/>
                            <TextBlock Text="默认导出格式" Foreground="White" Margin="0,0,0,5"/>
                            <ComboBox x:Name="DefaultExportFormatSelector" Margin="0,0,0,10">
                                <ComboBoxItem Content="PNG" IsSelected="True"/>
                                <ComboBoxItem Content="JPG"/>
                            </ComboBox>

                            <Button Content="💾 保存设置" Click="SaveConfig_Click"
                                    HorizontalAlignment="Stretch"/>
                            <Button Content="🔗 测试连接" Click="TestConnection_Click"
                                    HorizontalAlignment="Stretch" Background="#3E3E42" Margin="0,5,0,0"/>

                            <TextBlock x:Name="ConfigStatusText" Foreground="LightGreen" Margin="0,10,0,0"
                                       TextWrapping="Wrap"/>

                            <Separator Margin="0,15" Background="#3E3E42"/>

                            <TextBlock Text="关于" Foreground="#888" FontSize="11"/>
                            <TextBlock Text="CDR AI 助手 v1.0.0" Foreground="#666" FontSize="10"/>
                            <TextBlock Text="为 CorelDRAW 打造的 AI 插件" Foreground="#555" FontSize="10"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>